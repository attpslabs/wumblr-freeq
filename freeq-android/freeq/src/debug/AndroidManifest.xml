<?xml version="1.0" encoding="utf-8"?>
<!--
    Debug-only manifest overlay. Points the application at a network-
    security-config that allows cleartext to localhost so instrumented
    tests can run a MockWebServer. Release builds keep the platform
    default (cleartext blocked).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <application
        android:networkSecurityConfig="@xml/network_security_config_debug"
        tools:replace="android:networkSecurityConfig" />
</manifest>
